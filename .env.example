# ── Vercel Cron Secret (generate random string, set di Vercel Dashboard juga)
CRON_SECRET=ganti_dengan_random_string_panjang

# ── GNews API (daftar gratis di https://gnews.io → 100 request/hari)
GNEWS_API_KEY=your_gnews_api_key_here

# ── GitHub Personal Access Token (scope: repo)
# Buat di: GitHub → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=ghp_your_token_here

# ── GitHub Repo Info
GITHUB_REPO_OWNER=yuwandafauzi-theface
GITHUB_REPO_NAME=The-Face
